# ──────────────────────────────────────────────────────────────────────────
# MSL Platform — environment configuration template
# Copy to .env and fill in. NEVER commit a real .env. (NFR-04, §12)
# ──────────────────────────────────────────────────────────────────────────

# ── Node ──
NODE_ENV=development

# ── Postgres (docker-compose) ──
POSTGRES_USER=msl
POSTGRES_PASSWORD=msl_dev_password
POSTGRES_DB=msl_platform
POSTGRES_PORT=5432

# Prisma connection string (must match the Postgres vars above)
DATABASE_URL=postgresql://msl:msl_dev_password@localhost:5432/msl_platform?schema=public

# ── Redis / BullMQ ──
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── API ──
API_PORT=4000
API_GLOBAL_PREFIX=api/v1
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── Auth / JWT (AUTH-01/04) ──
# Generate strong random values for each environment; never reuse the examples.
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_REFRESH_TTL=7d
# bcrypt/argon2 work factor
PASSWORD_HASH_ROUNDS=12
# Brute-force protection (AUTH-05, G-14)
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

# ── Web (Next.js) ──
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_DEFAULT_LOCALE=mn

# ── Media / object storage + signed URLs (AUTH-09, G-7) ──
# Local dev can use a filesystem driver; production uses S3-compatible storage.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=msl-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
SIGNED_URL_TTL_SECONDS=900
MEDIA_MAX_BYTES=52428800
MEDIA_MAX_DURATION_SECONDS=60
MEDIA_ALLOWED_MIME=video/mp4,video/webm,image/png,image/jpeg

# ── Duplicate detection (G-4, S-34) — overridable in admin settings ──
DUPLICATE_TRIGRAM_THRESHOLD=0.45

# ── Email (G-14; optional teacher digest G-6, default off) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@msl.example
TEACHER_EMAIL_DIGEST_ENABLED=false

# ── Seed (Step 2) ──
SEED_ADMIN_EMAIL=admin@msl.example
SEED_ADMIN_PASSWORD=change_me_admin_password
